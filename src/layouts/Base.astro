---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { useTranslations, href, otherLang, type Lang, type RouteKey } from '../i18n';

interface Props {
  lang: Lang;
  routeKey: RouteKey;
  title: string;
  description: string;
  switchHref?: string;
}

const { lang, routeKey, title, description, switchHref } = Astro.props;
const t = useTranslations(lang);
const other = otherLang(lang);
const pageTitle = `${title} | ${t('site.name')} — ${t('site.uqtr')}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <link rel="alternate" hreflang={lang} href={Astro.url.pathname} />
    <link rel="alternate" hreflang={other} href={switchHref ?? href(other, routeKey)} />
  </head>
  <body>
    <a class="skip-link" href="#main">{lang === 'fr' ? 'Aller au contenu' : 'Skip to content'}</a>
    <Header lang={lang} routeKey={routeKey} switchHref={switchHref} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <script>
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduced && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12 }
        );
        const targets = document.querySelectorAll<HTMLElement>(
          'main .card, main .stats > div, main .pub-list li, main section.band, main h2'
        );
        // Only animate elements below the fold: content visible on load stays visible.
        targets.forEach((el, i) => {
          if (el.getBoundingClientRect().top < window.innerHeight * 0.92) return;
          el.classList.add('reveal');
          el.style.setProperty('--reveal-delay', `${(i % 5) * 70}ms`);
          io.observe(el);
        });
      }
    </script>
  </body>
</html>
