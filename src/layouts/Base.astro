---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { useTranslations, href, otherLang, type Lang, type RouteKey } from '../i18n';

interface Props {
  lang: Lang;
  routeKey: RouteKey;
  title: string;
  description: string;
}

const { lang, routeKey, title, description } = Astro.props;
const t = useTranslations(lang);
const other = otherLang(lang);
const pageTitle = `${title} | ${t('site.name')} — ${t('site.uqtr')}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <link rel="alternate" hreflang={lang} href={href(lang, routeKey)} />
    <link rel="alternate" hreflang={other} href={href(other, routeKey)} />
  </head>
  <body>
    <a class="skip-link" href="#main">{lang === 'fr' ? 'Aller au contenu' : 'Skip to content'}</a>
    <Header lang={lang} routeKey={routeKey} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
