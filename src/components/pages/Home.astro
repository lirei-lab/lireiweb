---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PublicationItem from '../PublicationItem.astro';
import EnergyGrid from '../EnergyGrid.astro';
import AxisIcon from '../AxisIcon.astro';
import { useTranslations, href, assetPath, type Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const team = await getCollection('team');
const pubs = (await getCollection('publications')).sort((a, b) => b.data.year - a.data.year);
const latest = pubs.slice(0, 5);
const featured = (await getCollection('projects')).filter((p) => p.data.featured);

const axes = ['smartgrids', 'residential', 'ml', 'hydrogen', 'flexibility', 'ev'] as const;
const partners = [
  'Hydro-Québec',
  'Ressources naturelles Canada',
  'Mitacs',
  'Université Laval',
  'Institut de recherche sur l’hydrogène (IRH)',
];
---

<Base lang={lang} routeKey="home" title={t('nav.home')} description={t('site.description')}>
  <div class="hero">
    <EnergyGrid />
    <div class="container">
      <h1>{t('site.fullname')}</h1>
      <p class="tagline">{t('home.tagline')}</p>
      <p class="intro">{t('home.intro')}</p>
      <p>
        <a class="btn" href={href(lang, 'research')}>{t('home.ctaResearch')}</a>
        <a class="btn outline" href={href(lang, 'publications')}>{t('home.ctaPubs')}</a>
      </p>
    </div>
  </div>

  <div class="container">
    <div class="stats">
      <div><span class="num">1999</span><span class="label">{t('home.statFounded')}</span></div>
      <div><span class="num">{team.length}</span><span class="label">{t('home.statMembers')}</span></div>
      <div><span class="num">{pubs.length}</span><span class="label">{t('home.statPubs')}</span></div>
      <div><span class="num">{axes.length}</span><span class="label">{t('home.statAxes')}</span></div>
    </div>

    <h2>{t('home.axesTitle')}</h2>
    <div class="grid-3">
      {axes.map((axis) => (
        <a class="card" href={`${href(lang, 'research')}#${axis}`} style="text-decoration:none">
          <div class="axis-head">
            <AxisIcon axis={axis} />
            <h3>{t(`research.axes.${axis}.title`)}</h3>
          </div>
          <p class="muted" style="font-size:0.92rem">{t(`research.axes.${axis}.desc`).slice(0, 110)}…</p>
        </a>
      ))}
    </div>

    <h2>{t('projects.featuredTitle')}</h2>
    <div class="grid-3">
      {featured.map((project) => (
        <a
          class="card featured-project"
          href={`${href(lang, 'projects')}/${project.id}`}
          style="text-decoration:none">
          {project.data.image && (
            <span class="project-img">
              <img
                src={assetPath(project.data.image)}
                alt={project.data.imageAlt?.[lang] ?? project.data.title[lang]}
                loading="lazy"
              />
            </span>
          )}
          <h3>{project.data.title[lang]}</h3>
          <p class="muted" style="font-size:0.92rem">{project.data.summary[lang]}</p>
        </a>
      ))}
    </div>
    <p><a href={href(lang, 'projects')}>{t('home.viewAll')} →</a></p>

    <h2>{t('home.pubsTitle')}</h2>
    <ul class="pub-list">
      {latest.map((pub) => <PublicationItem pub={pub} lang={lang} />)}
    </ul>
    <p><a href={href(lang, 'publications')}>{t('home.viewAll')} →</a></p>
  </div>

  <section class="band">
    <div class="container">
      <h2 style="margin-top:0">{t('home.partnersTitle')}</h2>
      <div class="partners-row">
        {partners.map((p) => <span>{p}</span>)}
      </div>
    </div>
  </section>

  <script>
    const nums = document.querySelectorAll<HTMLElement>('.stats .num');
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduced && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            io.unobserve(entry.target);
            const el = entry.target as HTMLElement;
            const end = parseInt(el.textContent ?? '', 10);
            if (!Number.isFinite(end) || end > 1000) continue; // skip the founding year
            const start = performance.now();
            const duration = 1100;
            const tick = (now: number) => {
              const p = Math.min(1, (now - start) / duration);
              el.textContent = String(Math.round(end * (1 - Math.pow(1 - p, 3))));
              if (p < 1) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
          }
        },
        { threshold: 0.5 }
      );
      nums.forEach((n) => io.observe(n));
    }
  </script>
</Base>
