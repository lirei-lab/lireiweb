---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import AxisIcon from '../AxisIcon.astro';
import ProjectCard from '../ProjectCard.astro';
import { useTranslations, href, assetPath, type Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const axes = ['smartgrids', 'residential', 'ml', 'hydrogen', 'flexibility', 'ev'] as const;

const programOrder = ['flexibilite', 'serres', 'communautes'] as const;
const all = await getCollection('projects');
const groups = programOrder.map((program) => {
  const inProgram = all.filter((p) => p.data.program === program);
  const flagship = inProgram.find((p) => p.data.featured);
  const subs = inProgram
    .filter((p) => !p.data.featured)
    .sort((a, b) => a.data.title[lang].localeCompare(b.data.title[lang]));
  return { program, flagship, subs };
});
---

<Base lang={lang} routeKey="research" title={t('research.title')} description={t('research.lead')}>
  <div class="hero hero--compact">
    <div class="container">
      <h1>{t('research.title')}</h1>
      <p class="intro">{t('research.lead')}</p>
    </div>
  </div>

  <div class="container">
    <h2 style="margin-top:2rem">{t('research.programsTitle')}</h2>
    <p class="muted" style="max-width:46rem">{t('projects.programsLead')}</p>
    <nav class="program-nav" aria-label={t('research.programsTitle')}>
      {groups.map(({ program }) => (
        <a href={`#${program}`}>{t(`projects.programs.${program}`)}</a>
      ))}
    </nav>
  </div>

  {groups.map(({ program, flagship, subs }, i) => (
    <section id={program} class={i % 2 === 1 ? 'band program-section' : 'program-section'}>
      <div class="container">
        {flagship && (
          <div class="program-head">
            {flagship.data.image && (
              <a class="program-illus" href={`${href(lang, 'research')}/${flagship.id}`}>
                <img
                  src={assetPath(flagship.data.image)}
                  alt={flagship.data.imageAlt?.[lang] ?? flagship.data.title[lang]}
                  loading="lazy"
                />
              </a>
            )}
            <div class="program-intro">
              <span class="tag">{t(`projects.programs.${program}`)}</span>
              <h3 class="program-title"><a href={`${href(lang, 'research')}/${flagship.id}`}>{flagship.data.title[lang]}</a></h3>
              <p>{flagship.data.summary[lang]}</p>
              {flagship.data.partners.length > 0 && (
                <p class="muted" style="font-size:0.9rem">
                  <strong>{t('projects.partners')} :</strong> {flagship.data.partners.join(', ')}
                </p>
              )}
              <p><a class="btn" href={`${href(lang, 'research')}/${flagship.id}`}>{t('projects.discover')} →</a></p>
            </div>
          </div>
        )}

        {subs.length > 0 && (
          <>
            <h4 class="subprojects-title">{t('projects.subprojects')}</h4>
            <div class="grid-3">
              {subs.map((project) => <ProjectCard project={project} lang={lang} compact />)}
            </div>
          </>
        )}
      </div>
    </section>
  ))}

  <div class="container">
    <h2>{t('research.axesTitle')}</h2>
    <p class="muted" style="max-width:46rem">{t('research.axesLead')}</p>
    <div class="grid-3">
      {axes.map((axis) => (
        <section class="card" id={axis}>
          <div class="axis-head">
            <AxisIcon axis={axis} />
            <h3>{t(`research.axes.${axis}.title`)}</h3>
          </div>
          <p class="muted" style="font-size:0.94rem">{t(`research.axes.${axis}.desc`)}</p>
          <p>
            {t(`research.axes.${axis}.tags`)
              .split(',')
              .map((tag) => <span class="tag">{tag.trim()}</span>)}
          </p>
        </section>
      ))}
    </div>
  </div>
</Base>
