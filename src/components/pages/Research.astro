---
import Base from '../../layouts/Base.astro';
import { useTranslations, type Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const axes = ['smartgrids', 'residential', 'ml', 'hydrogen', 'flexibility', 'ev'] as const;
---

<Base lang={lang} routeKey="research" title={t('research.title')} description={t('research.lead')}>
  <div class="container">
    <h1>{t('research.title')}</h1>
    <p class="lead">{t('research.lead')}</p>

    <div class="grid-2">
      {axes.map((axis) => (
        <section class="card" id={axis}>
          <h2 style="margin-top:0">{t(`research.axes.${axis}.title`)}</h2>
          <p>{t(`research.axes.${axis}.desc`)}</p>
          <p>
            {t(`research.axes.${axis}.tags`)
              .split(',')
              .map((tag) => <span class="tag">{tag.trim()}</span>)}
          </p>
        </section>
      ))}
    </div>
  </div>
</Base>
