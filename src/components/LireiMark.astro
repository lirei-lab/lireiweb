---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg class={className} viewBox="0 0 200 200" role="img" aria-label="LIREI" fill="none">
  <!-- back half of the orbit (behind the bolt) -->
  <g transform="rotate(7 100 100)">
    <ellipse cx="24.0" cy="89.2" rx="6.7" ry="4.1" fill="#2dbb80" />
    <ellipse cx="39.0" cy="69.8" rx="6.1" ry="3.8" fill="#199c6b" />
    <ellipse cx="66.2" cy="56.4" rx="5.7" ry="3.5" fill="#25af78" />
    <ellipse cx="100.0" cy="51.6" rx="5.6" ry="3.5" fill="#1fb6b0" />
    <ellipse cx="133.8" cy="56.4" rx="5.7" ry="3.5" fill="#22a9c1" />
    <ellipse cx="161.0" cy="69.8" rx="6.1" ry="3.8" fill="#25b9a0" />
    <ellipse cx="176.0" cy="89.2" rx="6.7" ry="4.1" fill="#2ebe86" />
  </g>
  <!-- bolt: flat, upright, XY plane -->
  <path d="M112 34 L72 106 L96 106 L86 166 L132 90 L104 90 L120 34 Z" fill="currentColor" />
  <!-- front half of the orbit (in front of the bolt) -->
  <g transform="rotate(7 100 100)">
    <ellipse cx="100.0" cy="148.4" rx="8.4" ry="5.2" fill="#1fb6b0" />
    <ellipse cx="66.2" cy="143.6" rx="8.3" ry="5.1" fill="#25af78" />
    <ellipse cx="39.0" cy="130.2" rx="7.9" ry="4.9" fill="#199c6b" />
    <ellipse cx="24.0" cy="110.8" rx="7.3" ry="4.5" fill="#2dbb80" />
    <ellipse cx="176.0" cy="110.8" rx="7.3" ry="4.5" fill="#2ebe86" />
    <ellipse cx="161.0" cy="130.2" rx="7.9" ry="4.9" fill="#25b9a0" />
    <ellipse cx="133.8" cy="143.6" rx="8.3" ry="5.1" fill="#22a9c1" />
  </g>
</svg>
