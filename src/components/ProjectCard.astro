---
import type { CollectionEntry } from 'astro:content';
import { useTranslations, type Lang } from '../i18n';

interface Props {
  project: CollectionEntry<'projects'>;
  lang: Lang;
}

const { project, lang } = Astro.props;
const t = useTranslations(lang);
const { title, summary, axis, status, partners } = project.data;
---

<article class="card" data-axis={axis}>
  <h3 style="margin-top:0">{title[lang]}</h3>
  <p>
    <span class="tag">{t(`research.axes.${axis}.title`)}</span>
    <span class="tag blue">{t(`projects.${status}`)}</span>
  </p>
  <p class="muted" style="font-size:0.94rem">{summary[lang]}</p>
  {partners.length > 0 && (
    <p class="muted" style="font-size:0.88rem">
      <strong>{t('projects.partners')} :</strong> {partners.join(', ')}
    </p>
  )}
</article>
