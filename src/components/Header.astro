---
import { useTranslations, navOrder, href, otherLang, type Lang, type RouteKey } from '../i18n';
import LireiMark from './LireiMark.astro';

interface Props {
  lang: Lang;
  routeKey: RouteKey;
  switchHref?: string;
}

const { lang, routeKey, switchHref } = Astro.props;
const t = useTranslations(lang);
const other = otherLang(lang);
---

<header class="site-header">
  <div class="container">
    <div class="brand">
      <a class="brand-link" href={href(lang, 'home')}>
        <LireiMark class="brand-mark" />
        <span class="brand-name">{t('site.name')}</span>
      </a>
      <span class="fullname">{t('site.fullname')} · {t('site.uqtr')}</span>
    </div>
    <nav class="site-nav" aria-label={t('nav.menuLabel')}>
      {navOrder.map((key) => (
        <a href={href(lang, key)} aria-current={key === routeKey ? 'page' : undefined}>
          {t(`nav.${key}`)}
        </a>
      ))}
      <a class="lang" href={switchHref ?? href(other, routeKey)} lang={other} aria-label={t('nav.langLabel')}>
        {other.toUpperCase()}
      </a>
    </nav>
  </div>
</header>
