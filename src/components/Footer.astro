---
import { useTranslations, href, type Lang } from '../i18n';
import LireiMark from './LireiMark.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="cols">
      <div>
        <a class="footer-brand" href={href(lang, 'home')}>
          <LireiMark class="footer-mark" />
          <span class="footer-name">{t('site.name')}</span>
        </a>
        <p>{t('site.fullname')}<br />{t('site.uqtr')}</p>
        <p>{t('footer.affiliation')}</p>
      </div>
      <div>
        <h3>{t('footer.contactTitle')}</h3>
        <p>
          <a href="mailto:lirei@irh.ca">lirei@irh.ca</a><br />
          {t('footer.phone')}
        </p>
        <p>{t('footer.address')}</p>
      </div>
      <div>
        <h3>{t('nav.research')}</h3>
        <p>
          <a href={href(lang, 'research')}>{t('nav.research')}</a><br />
          <a href={href(lang, 'publications')}>{t('nav.publications')}</a><br />
          <a href={href(lang, 'news')}>{t('nav.news')}</a>
        </p>
      </div>
    </div>
    <p class="fine">© {year} {t('site.name')} — {t('site.uqtr')}. {t('footer.rights')}</p>
  </div>
</footer>
