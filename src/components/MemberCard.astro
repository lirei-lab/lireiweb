---
import type { CollectionEntry } from 'astro:content';
import { assetPath, type Lang } from '../i18n';

interface Props {
  member: CollectionEntry<'team'>;
  lang: Lang;
}

const { member, lang } = Astro.props;
const { name, role, topic, affiliation, email, photo } = member.data;
const initials = name
  .split(/\s+/)
  .map((p) => p[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();
---

<div class="card member">
  {photo ? (
    <span class="avatar avatar--photo">
      <img src={assetPath(photo)} alt={name} loading="lazy" />
    </span>
  ) : (
    <svg class="avatar" width="72" height="72" viewBox="0 0 72 72" aria-hidden="true">
      <circle cx="36" cy="36" r="36" fill="var(--blue-100)" />
      <text
        x="36"
        y="46"
        text-anchor="middle"
        font-size="26"
        font-weight="700"
        fill="var(--blue-700)"
        font-family="system-ui, sans-serif">{initials}</text>
    </svg>
  )}
  <div>
    <h3>{name}</h3>
    <div class="role">{role[lang]}</div>
    {topic && <div class="topic">{topic[lang]}</div>}
    {affiliation && <div class="topic">{affiliation}</div>}
    {email && <div class="topic"><a href={`mailto:${email}`}>{email}</a></div>}
  </div>
</div>
